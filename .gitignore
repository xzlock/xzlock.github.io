_dev/

# ---------- 操作系统 ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- IDE / 编辑器 ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
venv/
env/
.venv/
.env

# ---------- Node.js（如果后续引入）----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ---------- 临时文件 ----------
*.log
*.tmp
*.bak
*.cache
.cache/
tmp/
temp/

# ---------- 本地测试产物 ----------
.local/
local_*
test_output/

# ---------- 敏感文件 ----------
*.env
*.key
*.pem
secrets/
config.local.*

